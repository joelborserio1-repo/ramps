---
import { COUNTERS } from '../config';

// Strip non-numeric placeholder noise so the counter has something to parse.
function numeric(value: string): string {
  const m = value.match(/[\d.]+/);
  return m ? m[0] : '0';
}

// Server-rendered final value, thousands-separated to match the JS count-up.
// Rendering the final number (not "0") means the stat is correct even before
// the count-up runs, if JS fails, or for crawlers.
function display(value: string): string {
  const raw = numeric(value);
  const n = parseFloat(raw);
  if (Number.isNaN(n)) return '0';
  const decimals = raw.includes('.') ? 1 : 0;
  return n.toLocaleString('en-AU', { minimumFractionDigits: decimals, maximumFractionDigits: decimals });
}

const cols = COUNTERS.length >= 4 ? 'lg:grid-cols-4' : 'lg:grid-cols-3';
---

<section aria-label="By the numbers" class="section bg-brand-cloud">
  <div class="container-page">
    <div class:list={['grid grid-cols-2 gap-8', cols]} data-stagger>
      {
        COUNTERS.map((c) => (
          <div class="text-center">
            <div class="flex items-baseline justify-center gap-0.5 text-4xl font-extrabold text-gradient-teal sm:text-5xl">
              <span data-counter={numeric(c.value)}>{display(c.value)}</span>
              <span>{c.suffix}</span>
            </div>
            <p class="mx-auto mt-3 max-w-[14rem] text-sm text-brand-slate">{c.label}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
