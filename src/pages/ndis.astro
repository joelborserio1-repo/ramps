---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import TrustBar from '../components/TrustBar.astro';
import SplitContent from '../components/SplitContent.astro';
import HowItWorks from '../components/HowItWorks.astro';
import Stats from '../components/Stats.astro';
import Reviews from '../components/Reviews.astro';
import FinalCTA from '../components/FinalCTA.astro';
import Footer from '../components/Footer.astro';
import MobileActionBar from '../components/MobileActionBar.astro';
import ClientBoot from '../components/ClientBoot.astro';

const ndisPoints = [
  {
    title: 'We liaise with your OT & coordinator',
    copy: 'Happy to work alongside your occupational therapist and support coordinator so the right ramp gets specified and approved.',
  },
  {
    title: 'However your plan is managed',
    copy: 'Self-managed, plan-managed or NDIA-managed — we provide clear, itemised quotes you can submit for your records.',
  },
  {
    title: 'Home modifications done properly',
    copy: 'Custom-built, recycled-rubber access ramps measured and installed by a qualified tradesman — safe and compliant.',
  },
  {
    title: 'Free on-site measure & quote',
    copy: 'We come to you, measure up and quote on the spot. No obligation to proceed.',
  },
];
---

<Layout
  title="NDIS Access Ramps Newcastle & the Hunter | Ramp Ability"
  description="NDIS-friendly recycled-rubber access ramps for participants across Newcastle & the Hunter. Custom-built by a qualified tradie. We liaise with OTs & support coordinators. Free on-site measure & quote."
  keywords="NDIS ramp Newcastle, NDIS access ramp, NDIS wheelchair ramp, NDIS ramp provider Hunter, NDIS home modifications ramp, NDIS approved ramp installer"
>
  <Header />
  <main>
    <Hero
      eyebrow="NDIS ramp specialists — Newcastle & the Hunter"
      subhead="NDIS-friendly access ramps for participants, custom-built from recycled rubber and installed by a qualified tradie. We're happy to liaise with your OT and support coordinator."
      ticks={[
        'Free on-site measure & quote',
        'We liaise with OTs & coordinators',
        'Recycled-rubber, non-slip',
        'Installed in days',
      ]}
    >
      <Fragment slot="headline">
        NDIS access ramps, <span class="text-gradient-teal">built to fit</span> — across Newcastle.
      </Fragment>
    </Hero>
    <TrustBar />
    <SplitContent
      eyebrow="NDIS made simple"
      heading="Ramps for NDIS participants, done properly"
      intro="We make funded access works straightforward — from the on-site measure to a clear quote you can submit and a tidy, qualified install."
      points={ndisPoints}
      bg="white"
      cta="Book my free quote"
    />
    <HowItWorks />
    <Stats />
    <Reviews />
    <FinalCTA />
  </main>
  <Footer />
  <MobileActionBar />
  <ClientBoot />
</Layout>
