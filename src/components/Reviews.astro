---
import reviewsData from '../data/reviews.json';
const reviews = reviewsData.reviews;
---

<section id="reviews" class="section bg-white">
  <div class="container-page">
    <div class="mx-auto max-w-2xl text-center reveal">
      <p class="eyebrow">What locals say</p>
      <h2 class="mt-4 text-3xl sm:text-4xl">Trusted across the Hunter</h2>
      <p class="mt-4 text-brand-slate">Real reviews from real customers.</p>
    </div>

    <div
      id="reviews-carousel"
      class="relative mx-auto mt-12 max-w-3xl reveal"
      role="region"
      aria-roledescription="carousel"
      aria-label="Customer reviews"
      tabindex="0"
    >
      <div class="overflow-hidden rounded-3xl">
        <div data-track class="flex transition-transform duration-500 ease-out" aria-live="polite">
          {
            reviews.map((r, i) => (
              <article
                data-slide
                class="w-full shrink-0 px-1"
                aria-roledescription="slide"
                aria-label={`Review ${i + 1} of ${reviews.length}`}
              >
                <div class="card mx-1 flex flex-col items-center text-center sm:p-10">
                  <div class="flex gap-1 text-brand-coral" aria-label={`${r.rating} out of 5 stars`}>
                    {Array.from({ length: r.rating }).map(() => (
                      <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                        <path d="M12 2l2.9 6.3 6.9.7-5.1 4.6 1.4 6.8L12 17.8 5.9 20.4l1.4-6.8L2.2 9l6.9-.7L12 2z" />
                      </svg>
                    ))}
                  </div>
                  <p class="mt-5 text-lg leading-relaxed text-brand-navy">“{r.text}”</p>
                  <div class="mt-6 flex items-center gap-3">
                    <span class="flex h-10 w-10 items-center justify-center rounded-full bg-teal-gradient text-sm font-bold text-white">
                      {r.name.replace(/\[|\]/g, '').trim().charAt(0) || '★'}
                    </span>
                    <div class="text-left">
                      <p class="text-sm font-semibold text-brand-navy">{r.name}</p>
                      <p class="text-xs text-brand-slate">{r.location}</p>
                    </div>
                    <span class="ml-2 inline-flex items-center gap-1 text-xs font-medium text-brand-slate">
                      <svg class="h-4 w-4" viewBox="0 0 24 24" aria-hidden="true">
                        <path fill="#4285F4" d="M21.6 12.2c0-.6-.05-1.2-.15-1.7H12v3.4h5.4a4.6 4.6 0 0 1-2 3v2.5h3.2c1.9-1.7 3-4.3 3-7.2z" />
                        <path fill="#34A853" d="M12 22c2.7 0 5-.9 6.6-2.4l-3.2-2.5c-.9.6-2 1-3.4 1-2.6 0-4.8-1.7-5.6-4.1H3.1v2.6A10 10 0 0 0 12 22z" />
                        <path fill="#FBBC05" d="M6.4 14a6 6 0 0 1 0-3.9V7.5H3.1a10 10 0 0 0 0 9z" />
                        <path fill="#EA4335" d="M12 6c1.5 0 2.8.5 3.8 1.5l2.8-2.8A10 10 0 0 0 3.1 7.5l3.3 2.6C7.2 7.7 9.4 6 12 6z" />
                      </svg>
                      Google
                    </span>
                  </div>
                </div>
              </article>
            ))
          }
        </div>
      </div>

      <!-- arrows -->
      <button
        data-prev
        type="button"
        aria-label="Previous review"
        class="absolute -left-2 top-1/2 z-10 flex h-11 w-11 -translate-y-1/2 items-center justify-center rounded-full border border-brand-line bg-white text-brand-navy shadow-soft transition-colors hover:border-brand-teal hover:text-brand-teal-deep sm:-left-5"
      >
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M15 6l-6 6 6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </button>
      <button
        data-next
        type="button"
        aria-label="Next review"
        class="absolute -right-2 top-1/2 z-10 flex h-11 w-11 -translate-y-1/2 items-center justify-center rounded-full border border-brand-line bg-white text-brand-navy shadow-soft transition-colors hover:border-brand-teal hover:text-brand-teal-deep sm:-right-5"
      >
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M9 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </button>

      <!-- dots -->
      <div data-dots class="mt-6 flex items-center justify-center gap-2" role="tablist" aria-label="Choose review"></div>
    </div>

    <p class="mt-6 text-center text-[11px] text-brand-slate/60">
      {/* Placeholder reviews — replace with verbatim Google reviews (src/data/reviews.json). */}
    </p>
  </div>
</section>
