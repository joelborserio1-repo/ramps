---
import RampMotif from './RampMotif.astro';

const services = [
  {
    title: 'Residential',
    copy: 'Safe access at home — wheelchair, mobility and threshold ramps in recycled rubber, custom-built to fit your entry.',
    href: '/rubber-ramps/',
  },
  {
    title: 'Aged Care',
    copy: 'Dignified, non-slip access for homes and facilities. Focused on preventing falls and keeping loved ones independent.',
    href: '/aged-care/',
  },
  {
    title: 'NDIS',
    copy: 'NDIS-friendly ramp installs for participants. Happy to liaise with your OT and support coordinator.',
    href: '/ndis/',
  },
];
---

<section id="services" class="section bg-white">
  <div class="container-page">
    <div class="mx-auto max-w-2xl text-center reveal">
      <p class="eyebrow">What we build</p>
      <h2 class="mt-4 text-3xl sm:text-4xl">Ramps for every kind of access</h2>
      <p class="mt-4 text-brand-slate">
        Residential, commercial and aged-care ramps — designed, made and installed by a local
        Hunter team.
      </p>
    </div>

    <div class="mt-12 grid gap-6 md:grid-cols-3" data-stagger>
      {
        services.map((s) => (
          <article class="card card-hover group flex flex-col">
            <div class="mb-5 flex h-14 w-14 items-center justify-center rounded-xl bg-brand-teal/10 text-brand-teal-deep transition-colors group-hover:bg-teal-gradient group-hover:text-white">
              <RampMotif class="h-7 w-7" />
            </div>
            <h3 class="text-xl font-bold">{s.title}</h3>
            <p class="mt-3 flex-1 text-sm leading-relaxed text-brand-slate">{s.copy}</p>
            <a
              href={s.href}
              class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-brand-teal-deep transition-colors hover:text-brand-teal"
            >
              See {s.title} ramps
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </a>
          </article>
        ))
      }
    </div>
  </div>
</section>
