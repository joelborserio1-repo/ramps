---
import { CONTACT } from '../config';
---

<header
  id="site-header"
  class="fixed inset-x-0 top-0 z-50 transition-all duration-300 border-b border-transparent"
>
  <div class="container-page flex items-center justify-between gap-4 py-4">
    <a href="#top" class="flex items-center" aria-label="Ramp Ability — back to top">
      <img
        src="/ramp-ability-logo.svg"
        alt="Ramp Ability"
        width="160"
        height="36"
        class="h-9 w-auto"
        fetchpriority="high"
      />
    </a>

    <nav class="flex items-center gap-3" aria-label="Primary">
      <a
        href={`tel:${CONTACT.phone.tel}`}
        data-call-source="header"
        class="hidden items-center gap-2 text-sm font-semibold text-brand-white hover:text-brand-orange transition-colors sm:inline-flex"
      >
        <svg class="h-4 w-4 text-brand-orange" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path
            d="M3 5.5C3 4.12 4.12 3 5.5 3h1.4c.5 0 .94.33 1.07.81l.9 3.3a1.1 1.1 0 0 1-.3 1.07l-1.3 1.3a14.5 14.5 0 0 0 5.95 5.95l1.3-1.3a1.1 1.1 0 0 1 1.07-.3l3.3.9c.48.13.81.57.81 1.07v1.4c0 1.38-1.12 2.5-2.5 2.5C10.6 21 3 13.4 3 5.5Z"
            stroke="currentColor"
            stroke-width="1.8"
          />
        </svg>
        <span>{CONTACT.phone.display}</span>
      </a>
      <a href="#quote" class="btn-primary !px-5 !py-2.5 text-sm">Get a Free Quote</a>
    </nav>
  </div>
</header>

<script>
  // Solidify the header background once the user scrolls past the hero fold.
  const header = document.getElementById('site-header');
  const onScroll = () => {
    if (!header) return;
    const solid = window.scrollY > 24;
    header.classList.toggle('bg-brand-black-pure/90', solid);
    header.classList.toggle('backdrop-blur-md', solid);
    header.classList.toggle('border-white/10', solid);
    header.classList.toggle('shadow-card', solid);
  };
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });
</script>
