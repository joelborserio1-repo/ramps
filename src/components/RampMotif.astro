---
/**
 * RampMotif — the signature visual device. The orange stepped triangle from
 * the logo, reused as a hero graphic, divider and animated element.
 *
 * Props:
 *  - variant: 'hero' (large animated build-in) | 'icon' (small inline mark)
 *  - class: extra classes for positioning
 */
interface Props {
  variant?: 'hero' | 'icon';
  class?: string;
}
const { variant = 'icon', class: className = '' } = Astro.props;
---

{variant === 'hero' ? (
  <svg
    class:list={['ramp-motif-hero', className]}
    viewBox="0 0 220 200"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    role="img"
    aria-label="Stylised access ramp"
  >
    <!-- glow -->
    <ellipse cx="120" cy="150" rx="110" ry="30" fill="url(#rampGlow)" opacity="0.5" />
    <!-- ascending steps -->
    <rect class="ramp-step" x="10" y="150" width="34" height="34" rx="4" fill="#F5821F" />
    <rect class="ramp-step" x="50" y="118" width="34" height="66" rx="4" fill="#F5821F" />
    <rect class="ramp-step" x="90" y="86" width="34" height="98" rx="4" fill="#FF7A00" />
    <rect class="ramp-step" x="130" y="54" width="34" height="130" rx="4" fill="#FF7A00" />
    <rect class="ramp-step" x="170" y="22" width="34" height="162" rx="4" fill="#FF7A00" />
    <!-- ramp slope: "draws" in -->
    <path
      class="ramp-slope"
      d="M14 150 L204 26"
      stroke="#FFFFFF"
      stroke-width="4"
      stroke-linecap="round"
    />
    <!-- traveller dot that rides up the ramp -->
    <circle class="ramp-traveller" cx="14" cy="150" r="8" fill="#FFFFFF" />
    <defs>
      <radialGradient id="rampGlow">
        <stop offset="0%" stop-color="#FF7A00" />
        <stop offset="100%" stop-color="#FF7A00" stop-opacity="0" />
      </radialGradient>
    </defs>
  </svg>
) : (
  <svg
    class:list={['inline-block', className]}
    viewBox="0 0 64 56"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    aria-hidden="true"
  >
    <rect x="4" y="40" width="11" height="12" rx="1.5" fill="currentColor" />
    <rect x="19" y="30" width="11" height="22" rx="1.5" fill="currentColor" />
    <rect x="34" y="20" width="11" height="32" rx="1.5" fill="currentColor" />
    <rect x="49" y="8" width="11" height="44" rx="1.5" fill="currentColor" />
    <path d="M4 40 L60 8" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" opacity="0.7" />
  </svg>
)}
