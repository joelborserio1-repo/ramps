---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import TrustBar from '../components/TrustBar.astro';
import Services from '../components/Services.astro';
import RampTypes from '../components/RampTypes.astro';
import WhyChoose from '../components/WhyChoose.astro';
import HowItWorks from '../components/HowItWorks.astro';
import Stats from '../components/Stats.astro';
import Reviews from '../components/Reviews.astro';
import FinalCTA from '../components/FinalCTA.astro';
import Footer from '../components/Footer.astro';
import MobileActionBar from '../components/MobileActionBar.astro';
import ClientBoot from '../components/ClientBoot.astro';
---

<Layout>
  <Header />
  <main>
    <Hero />
    <TrustBar />
    <Services />
    <RampTypes bg="cloud" />
    <WhyChoose bg="white" />
    <HowItWorks />
    <Stats />
    <Reviews />
    <FinalCTA />
  </main>
  <Footer />
  <MobileActionBar />
  <ClientBoot />
</Layout>
