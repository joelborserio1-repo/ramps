---
import { CONTACT, SERVICE_AREA, SITE } from '../config';
const year = new Date().getFullYear();
---

<footer class="border-t border-brand-line bg-brand-cloud pb-28 pt-16 sm:pb-16">
  <div class="container-page">
    <div class="grid gap-10 md:grid-cols-[1.2fr_1fr_1fr]">
      <div>
        <img src="/ramp-ability-logo.svg" alt="Ramp Ability" width="180" height="40" class="h-10 w-auto" />
        <p class="mt-4 max-w-xs text-sm leading-relaxed text-brand-slate">
          Safe, friendly access ramps designed, made and installed across the Hunter Region.
          Residential, commercial and aged care.
        </p>
      </div>

      <div>
        <h3 class="text-sm font-bold uppercase tracking-wider text-brand-navy">Service area</h3>
        <ul class="mt-4 grid grid-cols-2 gap-x-4 gap-y-2 text-sm text-brand-slate">
          {SERVICE_AREA.map((s) => <li>{s}</li>)}
        </ul>
      </div>

      <div>
        <h3 class="text-sm font-bold uppercase tracking-wider text-brand-navy">Get in touch</h3>
        <ul class="mt-4 space-y-2 text-sm">
          <li>
            <a
              href={`tel:${CONTACT.phone.tel}`}
              data-call-source="footer"
              class="font-semibold text-brand-navy transition-colors hover:text-brand-teal-deep"
            >
              {CONTACT.phone.display}
            </a>
          </li>
          <li class="pt-2">
            <a href="#quote" class="btn-primary !px-5 !py-2.5 text-sm">Get a Free Quote</a>
          </li>
        </ul>
      </div>
    </div>

    <nav
      class="mt-10 flex flex-wrap gap-x-5 gap-y-2 border-t border-brand-line pt-6 text-sm font-medium text-brand-slate"
      aria-label="Ramp pages"
    >
      <a href="/" class="transition-colors hover:text-brand-teal-deep">Access ramps</a>
      <a href="/rubber-ramps/" class="transition-colors hover:text-brand-teal-deep">Recycled-rubber ramps</a>
      <a href="/ndis/" class="transition-colors hover:text-brand-teal-deep">NDIS ramps</a>
      <a href="/aged-care/" class="transition-colors hover:text-brand-teal-deep">Aged-care ramps</a>
    </nav>

    <div
      class="mt-8 flex flex-col gap-3 border-t border-brand-line pt-6 text-xs text-brand-slate sm:flex-row sm:items-center sm:justify-between"
    >
      <p>© {year} {SITE.name}. All rights reserved.</p>
      <p class="text-brand-slate/70">
        Residential · Commercial · Aged Care — {SITE.region}
      </p>
    </div>
  </div>
</footer>
