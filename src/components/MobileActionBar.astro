---
import { CONTACT } from '../config';
---

<!-- Fixed bottom action bar — mobile only. This demographic calls: one tap. -->
<div
  class="fixed inset-x-0 bottom-0 z-50 grid grid-cols-2 gap-2 border-t border-brand-line bg-white/95 p-3 shadow-[0_-8px_24px_-12px_rgba(15,42,58,0.18)] backdrop-blur-md sm:hidden"
  role="region"
  aria-label="Quick actions"
>
  <a
    href={`tel:${CONTACT.phone.tel}`}
    data-call-source="mobile-bar"
    class="btn-ghost !py-3 text-base"
  >
    <svg class="h-5 w-5 text-brand-teal-deep" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path
        d="M3 5.5C3 4.12 4.12 3 5.5 3h1.4c.5 0 .94.33 1.07.81l.9 3.3a1.1 1.1 0 0 1-.3 1.07l-1.3 1.3a14.5 14.5 0 0 0 5.95 5.95l1.3-1.3a1.1 1.1 0 0 1 1.07-.3l3.3.9c.48.13.81.57.81 1.07v1.4c0 1.38-1.12 2.5-2.5 2.5C10.6 21 3 13.4 3 5.5Z"
        stroke="currentColor"
        stroke-width="1.8"
      />
    </svg>
    Call Now
  </a>
  <a href="#quote" class="btn-primary !py-3 text-base">Free Quote</a>
</div>
