---
import { CONTACT } from '../config';
import LeadForm from './LeadForm.astro';
import RampMotif from './RampMotif.astro';

const ticks = [
  'Free on-site measure & quote',
  'Fast installation',
  'Fully insured',
  'NDIS & aged-care friendly',
];
---

<section id="top" class="relative overflow-hidden bg-brand-black pt-28 pb-16 sm:pt-32 sm:pb-24">
  <!-- background glow + ramp geometry -->
  <div class="pointer-events-none absolute inset-0 bg-hero-glow" aria-hidden="true"></div>
  <div
    class="pointer-events-none absolute -right-20 top-40 hidden h-[480px] w-[480px] rounded-full bg-brand-orange/10 blur-[120px] lg:block"
    aria-hidden="true"
  >
  </div>

  <div class="container-page relative grid items-center gap-12 lg:grid-cols-[1.05fr_0.95fr]">
    <!-- LEFT: copy -->
    <div data-hero-stagger>
      <p class="eyebrow">Hunter Region's ramp specialists</p>

      <h1 class="mt-5 text-4xl leading-[1.05] sm:text-5xl lg:text-6xl">
        Safe, compliant access ramps —
        <span class="text-gradient-orange">installed fast</span> across the Hunter.
      </h1>

      <p class="mt-5 max-w-xl text-lg text-brand-grey">
        Custom residential, commercial and aged-care ramps. Free on-site measure and quote
        from a local, fully-insured Hunter team — so you can stay safe and independent at home.
      </p>

      <ul class="mt-7 grid max-w-xl gap-3 sm:grid-cols-2">
        {
          ticks.map((tick) => (
            <li class="flex items-center gap-2.5 text-sm font-medium text-brand-white">
              <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-orange-gradient">
                <svg class="h-3 w-3 text-brand-black-pure" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M5 13l4 4L19 7" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </span>
              {tick}
            </li>
          ))
        }
      </ul>

      <div class="mt-8 flex flex-wrap items-center gap-3">
        <a href="#quote" class="btn-primary text-lg">Get My Free Quote</a>
        <a
          href={`tel:${CONTACT.phone.tel}`}
          data-call-source="hero"
          class="btn-ghost"
        >
          <svg class="h-5 w-5 text-brand-orange" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path
              d="M3 5.5C3 4.12 4.12 3 5.5 3h1.4c.5 0 .94.33 1.07.81l.9 3.3a1.1 1.1 0 0 1-.3 1.07l-1.3 1.3a14.5 14.5 0 0 0 5.95 5.95l1.3-1.3a1.1 1.1 0 0 1 1.07-.3l3.3.9c.48.13.81.57.81 1.07v1.4c0 1.38-1.12 2.5-2.5 2.5C10.6 21 3 13.4 3 5.5Z"
              stroke="currentColor"
              stroke-width="1.8"
            />
          </svg>
          Call {CONTACT.phone.display}
        </a>
      </div>

      <!-- animated ramp motif under the copy on large screens -->
      <div class="mt-10 hidden max-w-[220px] lg:block" aria-hidden="true">
        <RampMotif variant="hero" class="w-full" />
      </div>
    </div>

    <!-- RIGHT: lead form (the hero of the hero) -->
    <div>
      <LeadForm />
    </div>
  </div>
</section>
