---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import MobileActionBar from '../components/MobileActionBar.astro';
import ClientBoot from '../components/ClientBoot.astro';
import { CONTACT } from '../config';
---

<Layout title="Page not found | Ramp Ability" noindex={true}>
  <Header />
  <main class="flex min-h-[70vh] items-center justify-center bg-white px-5 pt-28 pb-20 text-center">
    <div class="mx-auto max-w-xl">
      <p class="eyebrow">Error 404</p>
      <h1 class="mt-5 text-4xl sm:text-5xl">This page took a wrong turn.</h1>
      <p class="mt-4 text-lg text-brand-slate">
        The page you’re after isn’t here — but we can still help you get safe, easy access.
        Head back home for a free on-site measure and quote.
      </p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
        <a href="/" class="btn-primary text-lg">Back to home</a>
        <a href={`tel:${CONTACT.phone.tel}`} data-call-source="404" class="btn-ghost">
          Call {CONTACT.phone.display}
        </a>
      </div>
      <nav class="mt-10 flex flex-wrap justify-center gap-x-5 gap-y-2 text-sm font-medium text-brand-slate" aria-label="Popular pages">
        <a href="/rubber-ramps/" class="hover:text-brand-teal-deep">Recycled-rubber ramps</a>
        <a href="/ndis/" class="hover:text-brand-teal-deep">NDIS ramps</a>
        <a href="/aged-care/" class="hover:text-brand-teal-deep">Aged-care ramps</a>
      </nav>
    </div>
  </main>
  <Footer />
  <MobileActionBar />
  <ClientBoot />
</Layout>
